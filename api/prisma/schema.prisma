generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                              String               @id @default(uuid()) @db.Uuid
  email                                           String               @unique
  passwordHash                                    String
  role                                            Role                 @default(USER)
  isDeleted                                       Boolean              @default(false)
  createdAt                                       DateTime             @default(now())
  updatedAt                                       DateTime             @updatedAt

  // Relações
  AuditLog                                        AuditLog[]
  ClinicalHistory_ClinicalHistory_changedByToUser ClinicalHistory[]    @relation("ClinicalHistory_changedByToUser")
  histories                                       ClinicalHistory[]
  clinicalProfile                                 ClinicalProfile?
  resetTokens                                     PasswordResetToken[]
  publicCredentials                               PublicCredential?
  publicLinks                                     PublicLink[]
}

model ClinicalProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @db.Uuid
  firstName             String
  lastName              String
  sex                   String?
  emergencyContactName  String?
  emergencyContactPhone String?
  bloodType             String?
  allergies             String[]
  medications           String[]
  diseases              String[]
  surgeries             String[]
  consentAt             DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublicCredential {
  userId    String    @id @db.Uuid
  pinHash   String
  updatedAt DateTime  @updatedAt
  consentAt DateTime?            // <— única linha válida de consentAt (opcional)
  createdAt DateTime  @default(now())

  // Relações
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublicLink {
  id        String            @id @default(cuid())
  slug      String            @unique
  status    PublicLinkStatus  @default(ACTIVE)
  isActive  Boolean           @default(true)

  userId    String            @unique   // ⬅️ torne userId único
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model ClinicalHistory {
  id                                   String   @id @default(uuid()) @db.Uuid
  userId                               String   @db.Uuid
  snapshot                             Json
  changedAt                            DateTime @default(now())
  changedBy                            String?  @db.Uuid
  note                                 String?

  // Relações
  // ALTERAÇÃO AQUI: Adicionado onDelete: SetNull para permitir a exclusão do User
  User_ClinicalHistory_changedByToUser User?    @relation("ClinicalHistory_changedByToUser", fields: [changedBy], references: [id], onDelete: SetNull)
  user                                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String
  target    String?
  ip        String?  @db.Inet
  details   Json?
  createdAt DateTime @default(now())
  // Relações
  // ALTERAÇÃO AQUI: Adicionado onDelete: SetNull para permitir a exclusão do User
  User      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
}

enum PublicLinkStatus {
  ACTIVE
  REVOKED
}

enum Role {
  USER
}