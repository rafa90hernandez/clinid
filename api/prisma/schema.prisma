generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IdType {
  PASSPORT
  VISA
  DRIVER_LICENSE
  PPS
}

model User {
  id                                              String               @id @default(uuid()) @db.Uuid
  firstName                                       String?
  lastName                                        String?
  idType                                          IdType?
  idNumber                                        String?
  addressLine1                                    String?
  addressLine2                                    String?
  country                                         String?
  cityCounty                                      String?
  postalCode                                      String?
  phoneNumber                                     String?
  email                                           String               @unique
  passwordHash                                    String
  role                                            Role                 @default(USER)
  isDeleted                                       Boolean              @default(false)
  createdAt                                       DateTime             @default(now())
  updatedAt                                       DateTime             @updatedAt
  AuditLog                                        AuditLog[]
  ClinicalHistory_ClinicalHistory_changedByToUser ClinicalHistory[]    @relation("ClinicalHistory_changedByToUser")
  histories                                       ClinicalHistory[]
  clinicalProfile                                 ClinicalProfile?
  resetTokens                                     PasswordResetToken[]
  publicCredentials                               PublicCredential?
  publicLinks                                     PublicLink?
}

model ClinicalProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @db.Uuid
  sex                   String?
  emergencyContactName  String?
  emergencyContactPhone String?
  bloodType             String?
  allergies             String[]
  medications           String[]
  diseases              String[]
  surgeries             String[]
  consentAt             DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublicCredential {
  userId    String    @id @db.Uuid
  pinHash   String
  updatedAt DateTime  @updatedAt
  consentAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublicLink {
  id        String           @id @default(cuid()) @db.Uuid
  userId    String           @unique @db.Uuid
  slug      String           @unique
  status    PublicLinkStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  revokedAt DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ClinicalHistory {
  id                                   String   @id @default(uuid()) @db.Uuid
  userId                               String   @db.Uuid
  snapshot                             Json
  changedAt                            DateTime @default(now())
  changedBy                            String?  @db.Uuid
  note                                 String?
  User_ClinicalHistory_changedByToUser User?    @relation("ClinicalHistory_changedByToUser", fields: [changedBy], references: [id])
  user                                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String
  target    String?
  ip        String?  @db.Inet
  details   Json?
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [actorId], references: [id])

  @@index([action])
  @@index([createdAt])
}

enum PublicLinkStatus {
  ACTIVE
  REVOKED
}

enum Role {
  USER
}
